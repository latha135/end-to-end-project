{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "adfdevecommb10"
		},
		"LS_AZSQLDB_METADATA_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'LS_AZSQLDB_METADATA'"
		},
		"LS_AZADLS_PARAM_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "@{linkedService().storage_account_loc}"
		},
		"LS_AZSQLDB_METADATA_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "sql-serverb10.database.windows.net"
		},
		"LS_AZSQLDB_METADATA_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "sql-servervbb10"
		},
		"LS_AZSQLDB_METADATA_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "shiva"
		},
		"LS_RESTAPI_SOURCE_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://retoolapi.dev/JMe24c/data"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "adfdevecommb10_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"LS_AZSQLDB_METADATA_password": {
						"value": "[parameters('LS_AZSQLDB_METADATA_password')]"
					},
					"LS_AZADLS_PARAM_properties_typeProperties_url": {
						"value": "[parameters('LS_AZADLS_PARAM_properties_typeProperties_url')]"
					},
					"LS_AZSQLDB_METADATA_properties_typeProperties_server": {
						"value": "[parameters('LS_AZSQLDB_METADATA_properties_typeProperties_server')]"
					},
					"LS_AZSQLDB_METADATA_properties_typeProperties_database": {
						"value": "[parameters('LS_AZSQLDB_METADATA_properties_typeProperties_database')]"
					},
					"LS_AZSQLDB_METADATA_properties_typeProperties_userName": {
						"value": "[parameters('LS_AZSQLDB_METADATA_properties_typeProperties_userName')]"
					},
					"LS_RESTAPI_SOURCE_properties_typeProperties_url": {
						"value": "[parameters('LS_RESTAPI_SOURCE_properties_typeProperties_url')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}